AI_GATEWAY_API_KEY=

# Optional AWS read-through cache.
AWS_REGION=
# AWS_DEFAULT_REGION= also works if using AWS CLI-style env output.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
PARALLAX_S3_BUCKET=
